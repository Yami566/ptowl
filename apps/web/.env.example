# PTOwl frontend — local dev environment template.
#
# Copy this file to `.env.local` for local overrides. Vite reads `.env.local`
# automatically (gitignored). In production the values come from Cloudflare
# Workers Builds → Environment variables.
#
# All VITE_* values are baked into the bundle at build time and are visible
# to anyone who views the deployed JavaScript. Never put secrets here.

# Clerk publishable key (pk_*). Designed for browser exposure per Clerk's
# security model: https://clerk.com/docs/deployments/overview#publishable-keys
#
# The value below is the production instance key (clerk.ptowl.com). It is
# also baked into apps/web/src/main.tsx as the fallback, so a missing env
# var doesn't break local dev. Override here if you're pointing at a
# separate dev Clerk instance.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_Y2xlcmsucHRvd2wuY29tJA
