# Hashed asset bundles — vite emits content-hashed filenames in /assets/
# (e.g. index-u8b1TWpL.js), so they're effectively immutable. Tell the
# browser to cache them for a year and skip revalidation. Major win for
# repeat-visit perf without any cache-invalidation risk.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Everything else — security headers + default revalidating cache.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-XSS-Protection: 1; mode=block
  # font-src includes data: — Clerk's @clerk/clerk-react SDK ships its
  # icon set as a base64-encoded TTF inlined as a data: URL. Without
  # this, every Clerk widget logs CSP violations to the browser
  # console and falls back to default fonts (icons render as boxes).
  # Surfaced by scripts/e2e-live.mjs on 2026-05-16.
