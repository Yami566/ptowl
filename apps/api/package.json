{
  "name": "@ptowl/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local --persist-to .wrangler/state",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint ok'",
    "test": "vitest run",
    "test:unit": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply ptowl-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply ptowl-db --remote"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@ptowl/shared": "workspace:*",
    "hono": "^4.6.0",
    "ical-generator": "^8.1.1",
    "jose": "^6.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260429.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.86.0"
  }
}
