{
  "name": "ptowl",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @ptowl/api dev",
    "dev:web": "pnpm --filter @ptowl/web dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @ptowl/shared build",
    "build:api": "pnpm --filter @ptowl/api build",
    "build:web": "pnpm --filter @ptowl/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2"
  }
}
