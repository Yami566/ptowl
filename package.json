{
  "name": "ptowl",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter @ptowl/api dev",
    "dev:web": "pnpm --filter @ptowl/web dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @ptowl/shared build",
    "build:api": "pnpm --filter @ptowl/api build",
    "build:web": "pnpm --filter @ptowl/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commitlint": "commitlint",
    "launch:finalize": "node scripts/finalize-launch.mjs",
    "audit:secrets": "node scripts/audit-secrets.mjs",
    "clerk:user": "node scripts/clerk-user.mjs",
    "test:e2e": "node scripts/e2e-live.mjs",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd",
      "sharp"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@playwright/test": "^1.60.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "playwright": "1.49.0",
    "prettier": "^3.4.2"
  }
}
